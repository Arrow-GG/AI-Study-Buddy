# AI Study Assistant - Root Configuration

# See backend/.env.example and frontend/.env.example for service-specific configuration

# Docker Compose Configuration
COMPOSE_PROJECT_NAME=ai-study-assistant

# Database
DB_USER=postgres
DB_PASSWORD=change-me
DB_NAME=ai_study_assistant
SECRET_KEY=replace-with-a-long-random-secret
CORS_ORIGINS=https://noted.io,https://www.noted.io
NEXT_PUBLIC_API_URL=https://api.noted.io/api
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-1.5-pro
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Services will be accessible at:
# Frontend: http://localhost:3000
# Backend API: http://localhost:8000
# API Docs: http://localhost:8000/api/docs
# PostgreSQL: localhost:5432
# Redis: localhost:6379
